PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Option 1: single connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/milking_tracker

# Option 2: individual values (used if DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGDATABASE=milking_tracker
PGUSER=postgres
PGPASSWORD=postgres
